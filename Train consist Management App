public class TrainApp {

    public static long loopSum(List<Integer> list) {
        long sum = 0;
        for(int i : list) sum += i;
        return sum;
    }

    public static long streamSum(List<Integer> list) {
        return list.stream().reduce(0, Integer::sum);
    }

    public static void main(String[] args) {
        List<Integer> list = new ArrayList<>();
        for(int i=0;i<10000;i++) list.add(i);

        System.out.println(loopSum(list));
        System.out.println(streamSum(list));
    }
}import org.junit.jupiter.api.Test;
 import java.util.*;
 import static org.junit.jupiter.api.Assertions.*;

 public class TrainAppTest {

     @Test
     void testPerformanceEquality() {
         List<Integer> list = Arrays.asList(1,2,3,4);

         assertEquals(
                 TrainApp.loopSum(list),
                 TrainApp.streamSum(list)
         );
     }
 }public class TrainAppTest {

    @Test
    void testSafety() {
        List<Bogie> list = Arrays.asList(
                new Bogie("Goods", true),
                new Bogie("Goods", false)
        );

        assertFalse(TrainApp.checkSafety(list));
    }
} public class TrainApp {

     public static boolean checkSafety(List<Bogie> list) {
         return list.stream()
                 .filter(b -> b.type.equals("Goods"))
                 .allMatch(b -> b.safety);
     }

     public static void main(String[] args) {
         List<Bogie> list = Arrays.asList(
                 new Bogie("Goods", true),
                 new Bogie("Goods", true)
         );

         System.out.println(checkSafety(list));
     }
