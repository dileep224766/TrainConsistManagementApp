} public class TrainApp {

     public static int totalSeats(List<Bogie> list) {
         return list.stream().map(b -> b.seats).reduce(0, Integer::sum);
     }

     public static void main(String[] args) {
         List<Bogie> list = Arrays.asList(
                 new Bogie(72),
                 new Bogie(60)
         );

         System.out.println(totalSeats(list));
     }
