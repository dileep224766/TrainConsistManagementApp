import static org.junit.jupiter.api.Assertions.*;

public class TrainAppTest {

    @Test
    void testTotalSeats() {
        List<Bogie> list = Arrays.asList(
                new Bogie(10),
                new Bogie(20)
        );

        assertEquals(30, TrainApp.totalSeats(list));
